# Rubberband environment reference
# Copy to .env for local development. Values in .env/process env are locked in the Settings UI.

###############################################################################
# Server
###############################################################################

# HTTP port for the built Express server. Vite dev UI still uses vite.config.ts.
PORT=8765

# Optional mount path for the built Express app and API, for example /rubberband.
# Leave blank or set to / to serve from the domain root.
BASE_PATH=

# info | debug | warn | error. DEBUG_LOGGING=true is equivalent to debug.
SERVER_LOG_LEVEL=info
DEBUG_LOGGING=false

# Anonymous browser/API session lifetime in milliseconds. Default: 8 hours.
SESSION_TTL_MS=28800000

###############################################################################
# LLM / OpenAI-compatible API
###############################################################################

# OpenAI-compatible base URL. Can be either /v1 or the full /v1/chat/completions URL.
OPENAI_BASE_URL=https://api.openai.com/v1

# Required for model-driven chat, normal MCP tool loops, and Deep Agent analysis.
OPENAI_API_KEY=sk-example

# Authorization header scheme. Use Bearer for OpenAI-compatible APIs, or none for raw key auth.
OPENAI_AUTH_SCHEME=Bearer

# Model name sent to the configured LLM provider.
OPENAI_MODEL=gpt-4.1-mini

# Optional chat-completions tuning. Leave blank to let the provider defaults apply.
OPENAI_TEMPERATURE=
OPENAI_TOP_P=
OPENAI_MAX_TOKENS=
OPENAI_TIMEOUT_MS=90000

# Optional JSON object merged into LLM request headers/body.
# Example headers: {"OpenAI-Organization":"org_..."}
# Example body for provider routing metadata: {"metadata":{"app":"rubberband","environment":"local"}}
# Example body to disable parallel tool calls on compatible providers: {"parallel_tool_calls":false}
# Example body for custom gateway/provider options: {"user":"rubberband-local","seed":1234}
# Do not include model, messages, or tools here; Rubberband sets those per request.
OPENAI_EXTRA_HEADERS=
OPENAI_EXTRA_BODY=

###############################################################################
# Elasticsearch
###############################################################################

# Use either ELASTICSEARCH_URL or ELASTICSEARCH_CLOUD_ID, depending on the MCP app.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_CLOUD_ID=

# Prefer API key auth. Security/Observability MCP apps require an API key.
ELASTICSEARCH_API_KEY=

# Optional fallback credentials. Rubberband will not create an Elasticsearch API
# key from these unless ELASTICSEARCH_AUTO_CREATE_API_KEY is explicitly enabled.
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=

# Off by default to preserve read-only behavior. Enabling this writes an API key
# to Elasticsearch security state for child MCP app authentication.
ELASTICSEARCH_AUTO_CREATE_API_KEY=false

# Expiration for API keys generated from ELASTICSEARCH_USERNAME/PASSWORD when
# ELASTICSEARCH_AUTO_CREATE_API_KEY=true.
GENERATED_ELASTICSEARCH_API_KEY_EXPIRATION=8h

# Cross-cluster search defaults. When enabled, Rubberband includes these targets
# in Elastic prompt guidance, background profiling, and child MCP app env.
# Patterns use Elasticsearch wildcard syntax, not regex. Alias-only patterns
# such as remote-prod* are normalized to remote-prod*:*.
ELASTIC_CCS_SEARCH_BY_DEFAULT=false
ELASTIC_CCS_INDEX_PATTERNS=
ELASTIC_CCS_RESOLVE_TIMEOUT_MS=5000

# Elastic Security's current MCP app expects CLUSTERS_JSON or CLUSTERS_FILE.
# Rubberband auto-generates CLUSTERS_JSON from ELASTICSEARCH_URL, KIBANA_URL,
# KIBANA_SPACE_ID, and ELASTICSEARCH_API_KEY when neither override is set.
# Set one of these only when you need explicit multi-cluster config or a file.
CLUSTERS_JSON=
CLUSTERS_FILE=

###############################################################################
# Kibana
###############################################################################

KIBANA_URL=http://localhost:5601

# Optional Kibana space. Rubberband passes MCP apps a space-qualified URL:
# http://localhost:5601/s/my-space
KIBANA_SPACE_ID=

# If blank, Rubberband falls back to matching Elasticsearch credentials for MCP apps.
KIBANA_API_KEY=
KIBANA_USERNAME=
KIBANA_PASSWORD=

###############################################################################
# Trino / Starburst
###############################################################################

# Used by mcp-app-trino
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_SCHEME=http
TRINO_SSL=
TRINO_USER=trino
TRINO_PASSWORD=
TRINO_ACCESS_TOKEN=
TRINO_AUTH_TYPE=none
TRINO_CATALOG=tpch
TRINO_SCHEMA=tiny
TRINO_SOURCE=rubberband
TRINO_INSECURE_TLS=false
TRINO_CA_CERT_FILE=
TRINO_CA_CERT=
TRINO_CLIENT_CERT_FILE=
TRINO_CLIENT_CERT=
TRINO_CLIENT_KEY_FILE=
TRINO_CLIENT_KEY=
TRINO_CLIENT_KEY_PASSPHRASE=

# Optional Starburst-prefixed aliases for environments that separate naming.
STARBURST_HOST=
STARBURST_PORT=
STARBURST_SCHEME=
STARBURST_USER=
STARBURST_PASSWORD=
STARBURST_ACCESS_TOKEN=
STARBURST_CATALOG=
STARBURST_SCHEMA=
STARBURST_INSECURE_TLS=false
STARBURST_CA_CERT_FILE=
STARBURST_CLIENT_CERT_FILE=
STARBURST_CLIENT_KEY_FILE=

###############################################################################
# Visualization contract
###############################################################################

# Shared presentation defaults that Rubberband passes to prompts and MCP app
# processes. Apps should use these where supported and keep native functionality
# available where a renderer has richer behavior.
RUBBERBAND_VIZ_THEME=light
RUBBERBAND_VIZ_PALETTE=elastic
RUBBERBAND_VIZ_DENSITY=comfortable
RUBBERBAND_VIZ_LEGEND=right
RUBBERBAND_VIZ_TOOLTIP=shared
RUBBERBAND_VIZ_TIMEZONE=browser
RUBBERBAND_VIZ_NATIVE_FEATURES=true

###############################################################################
# Domain knowledge
###############################################################################

# Optional global domain knowledge shared by all users when set here.
# Leave blank to let each browser session set its own private value in Settings.
# Example:
# DOMAIN_KNOWLEDGE=myalertindex-* contains custom alerts. created_at is timestamp.
# risk.level is severity. alert_state is status. host_name and username are entities.
DOMAIN_KNOWLEDGE=

###############################################################################
# TLS
###############################################################################

# Master switch for self-signed/internal certificates. This disables Node TLS
# certificate verification for Rubberband server-side outbound requests and
# passes equivalent insecure-TLS flags to child MCP app processes.
# It cannot change browser certificate validation for the user's HTTPS
# connection to the Rubberband web server.
ALLOW_INSECURE_TLS=false

###############################################################################
# MCP app installation/runtime
###############################################################################

# Build/install-time config used by scripts/install-mcp-apps.mjs.
MCP_APPS_CONFIG=mcp-apps.json

# Install output directory for cloned/unpacked MCP apps.
MCP_APPS_DIR=mcp_apps

# Installed-app manifest written by installer and read at runtime.
MCP_APPS_OUTPUT=mcp-apps.installed.json
MCP_APPS_MANIFEST=mcp-apps.installed.json

###############################################################################
# Normal LLM tool loop limits
###############################################################################

# Maximum model/tool-call turns for the normal MCP tool loop.
MAX_TOOL_LOOPS=16

# Maximum serialized tool result characters sent back to the model.
MAX_TOOL_RESULT_CHARS=12000

# Maximum selected app skills and skill text included in the system prompt.
MAX_SKILLS_PER_APP=8
MAX_SKILL_CHARS=2600

# Recent chat context retained for normal tool-loop calls.
MAX_CONTEXT_MESSAGES=40
MAX_CONTEXT_MESSAGE_CHARS=3000

###############################################################################
# MCP exposure and tool safety
###############################################################################

# Optional instance allow/deny policy. Empty means all installed apps/tools are
# eligible. Patterns are case-insensitive wildcards, not regular expressions.
# Tool patterns use appId:toolName. Deny lists win over allow lists.
# Example:
# MCP_ENABLED_APPS=dashbuilder,mcp-app-trino
# MCP_ENABLED_TOOLS=dashbuilder:create_chart,mcp-app-trino:*
MCP_ENABLED_APPS=
MCP_DISABLED_APPS=
MCP_ENABLED_TOOLS=
MCP_DISABLED_TOOLS=

# Enabled by default. Rubberband hides and blocks MCP tools that appear to mutate
# external systems, and blocks mutating SQL/API arguments at execution time.
MCP_READ_ONLY_MODE=true

# Optional escape hatch for false positives, one wildcard per line or comma item.
# Even allowlisted tools are still checked for mutating SQL/API arguments.
MCP_READ_ONLY_TOOL_ALLOWLIST=

# Optional startup audit log. When true, Rubberband starts eligible MCP apps once
# on boot, logs the apps/tools exposed after instance and read-only filtering,
# then closes that audit registry.
MCP_EXPOSURE_REPORT_ON_STARTUP=false

###############################################################################
# Background analytics profiler / catalog cache
###############################################################################

# Runs shared read-only metadata profiles outside the chat request path. Chat
# uses the latest successful snapshot and schedules a refresh when snapshots are
# stale or missing.
ANALYTICS_PROFILER_ENABLED=true
ANALYTICS_PROFILER_RUN_ON_STARTUP=true
ANALYTICS_PROFILER_TARGETS=all
ANALYTICS_PROFILER_SCHEDULE_MS=86400000
ANALYTICS_PROFILER_STALE_AFTER_MS=86400000
ANALYTICS_PROFILER_STORAGE_FILE=.rubberband/analytics-profile.json

###############################################################################
# Deep Agent / profiler internals
###############################################################################

# Timeout for Deep Agent LLM calls in milliseconds.
DEEP_AGENT_LLM_TIMEOUT_MS=90000

# Maximum LangGraph Deep Agent recursion steps before the agent is stopped.
DEEP_AGENT_RECURSION_LIMIT=32

# Maximum MCP tool calls a Deep Analysis chat turn may run.
MAX_DEEP_AGENT_TOOL_CALLS=24

# Maximum compact MCP tool-result characters returned to the Deep Agent.
MAX_DEEP_AGENT_RESULT_CHARS=4000

# Bounded read-only Elastic profiler defaults.
ELASTIC_PROFILER_MAX_INDICES=40
ELASTIC_PROFILER_MAX_FIELD_CAPS=12
ELASTIC_PROFILER_MAX_FIELDS_PER_INDEX=80
ELASTIC_PROFILER_TIMEOUT_MS=8000
ELASTIC_PROFILER_INCLUDED_PATTERNS=
ELASTIC_PROFILER_EXCLUDED_PATTERNS=.*,ilm-history-*,slm-history-*
ELASTIC_PROFILER_INCLUDE_DATA_STREAMS=true
ELASTIC_PROFILER_INCLUDE_SYSTEM=false

# Bounded read-only Trino / Starburst profiler defaults. Keep these conservative
# for catalogs with thousands of tables; the profiler inspects only bounded table
# candidates and their columns.
TRINO_PROFILER_MAX_CATALOGS=8
TRINO_PROFILER_MAX_TABLES_PER_CATALOG=30
TRINO_PROFILER_MAX_COLUMN_TABLES_PER_CATALOG=12
TRINO_PROFILER_MAX_COLUMNS_PER_CATALOG=600
TRINO_PROFILER_INCLUDED_CATALOGS=
TRINO_PROFILER_EXCLUDED_CATALOGS=system,jmx,memory,information_schema
TRINO_PROFILER_CONCURRENCY=3
TRINO_PROFILER_CACHE_TTL_MS=86400000
TRINO_PROFILER_TIMEOUT_MS=12000
TRINO_PROFILER_STATEMENT_TIMEOUT_MS=60000
TRINO_PROFILER_MAX_PAGES_PER_STATEMENT=80

###############################################################################
# Test/smoke helper variables
###############################################################################

# Used by npm run test:docker.
DOCKER_IMAGE=rubberband-mcp-chat:test
DOCKER_SMOKE_PORT=

# Used by npm run test:live.
LIVE_SMOKE_PORT=
