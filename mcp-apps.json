{
  "apps": [
    {
      "id": "dashbuilder",
      "name": "Elastic Dashbuilder",
      "description": "Build, preview, import, and export Kibana dashboards with MCP Apps.",
      "source": {
        "type": "git",
        "url": "https://github.com/elastic/example-mcp-dashbuilder.git",
        "ref": "21ce3b2a57327614aebc9f2ca55ffe371d0df0ed"
      },
      "install": [
        ["npm", "install"],
        ["npm", "run", "build"]
      ],
      "transport": {
        "type": "stdio",
        "command": "npm",
        "args": ["run", "start"],
        "cwd": "${appDir}"
      },
      "envPassthrough": [
        "ELASTICSEARCH_URL",
        "ELASTICSEARCH_CLOUD_ID",
        "ELASTICSEARCH_API_KEY",
        "ELASTICSEARCH_USERNAME",
        "ELASTICSEARCH_PASSWORD",
        "ELASTIC_CCS_SEARCH_BY_DEFAULT",
        "ELASTIC_CCS_INDEX_PATTERNS",
        "ELASTIC_CCS_RESOLVE_TIMEOUT_MS",
        "KIBANA_URL",
        "KIBANA_SPACE_ID",
        "KIBANA_API_KEY",
        "KIBANA_USERNAME",
        "KIBANA_PASSWORD",
        "NODE_TLS_REJECT_UNAUTHORIZED"
      ]
    },
    {
      "id": "security",
      "name": "Elastic Security",
      "description": "Interactive SOC workflows for alerts, cases, rules, threat hunting, and sample ECS security data.",
      "source": {
        "type": "git",
        "url": "https://github.com/elastic/example-mcp-app-security.git",
        "ref": "86ddc3d743d41a8b42fa51d643d3befc83d99163"
      },
      "install": [
        ["npm", "install"],
        ["npm", "run", "build"]
      ],
      "transport": {
        "type": "stdio",
        "command": "npm",
        "args": ["run", "start:stdio"],
        "cwd": "${appDir}"
      },
      "envPassthrough": [
        "ELASTICSEARCH_URL",
        "ELASTICSEARCH_CLOUD_ID",
        "ELASTICSEARCH_API_KEY",
        "ELASTICSEARCH_USERNAME",
        "ELASTICSEARCH_PASSWORD",
        "ELASTIC_CCS_SEARCH_BY_DEFAULT",
        "ELASTIC_CCS_INDEX_PATTERNS",
        "ELASTIC_CCS_RESOLVE_TIMEOUT_MS",
        "CLUSTERS_JSON",
        "CLUSTERS_FILE",
        "KIBANA_URL",
        "KIBANA_SPACE_ID",
        "KIBANA_API_KEY",
        "KIBANA_USERNAME",
        "KIBANA_PASSWORD",
        "NODE_TLS_REJECT_UNAUTHORIZED"
      ]
    },
    {
      "id": "observability",
      "name": "Elastic Observability",
      "description": "Interactive SRE workflows for observability, APM, Kubernetes, ML anomalies, and alert rules.",
      "source": {
        "type": "git",
        "url": "https://github.com/elastic/example-mcp-app-observability.git",
        "ref": "cd5f7d936106fdf671fb24ca2b33ac300ee55ed9"
      },
      "install": [
        ["npm", "install"],
        ["npm", "run", "build"]
      ],
      "skillPacks": [
        {
          "name": "apm-health-summary.zip",
          "url": "https://github.com/elastic/example-mcp-app-observability/releases/download/v1.1.1/apm-health-summary.zip",
          "sha256": "8ec8737be8534ea573badfb05816d98518067b8eaa31ad2740064785d7554e13"
        },
        {
          "name": "apm-service-dependencies.zip",
          "url": "https://github.com/elastic/example-mcp-app-observability/releases/download/v1.1.1/apm-service-dependencies.zip",
          "sha256": "02c95dcca9465751fabb3e900323f8a30a6637b57d744e48499f34f41a105720"
        },
        {
          "name": "k8s-blast-radius.zip",
          "url": "https://github.com/elastic/example-mcp-app-observability/releases/download/v1.1.1/k8s-blast-radius.zip",
          "sha256": "ed615ee9039555456aafba7d8289625db55b7a3af88739e86942329f3fb9e0af"
        },
        {
          "name": "manage-alerts.zip",
          "url": "https://github.com/elastic/example-mcp-app-observability/releases/download/v1.1.1/manage-alerts.zip",
          "sha256": "4413ec37bd6259155d02c78c58d98ab4dd0d9b341d19bfaf180362c2c2bceba9"
        },
        {
          "name": "ml-anomalies.zip",
          "url": "https://github.com/elastic/example-mcp-app-observability/releases/download/v1.1.1/ml-anomalies.zip",
          "sha256": "7849e460a16b651e7da86e60e424ac0a98b35df4bde47a261ce7fbd8484d570a"
        },
        {
          "name": "observe.zip",
          "url": "https://github.com/elastic/example-mcp-app-observability/releases/download/v1.1.1/observe.zip",
          "sha256": "77c5774e0642e2bd6f97f0f3b6cba937aaf3f910b4985c0af8bfc5e539e0a979"
        }
      ],
      "transport": {
        "type": "stdio",
        "command": "npm",
        "args": ["run", "start:stdio"],
        "cwd": "${appDir}"
      },
      "envPassthrough": [
        "ELASTICSEARCH_URL",
        "ELASTICSEARCH_CLOUD_ID",
        "ELASTICSEARCH_API_KEY",
        "ELASTICSEARCH_USERNAME",
        "ELASTICSEARCH_PASSWORD",
        "ELASTIC_CCS_SEARCH_BY_DEFAULT",
        "ELASTIC_CCS_INDEX_PATTERNS",
        "ELASTIC_CCS_RESOLVE_TIMEOUT_MS",
        "CLUSTERS_JSON",
        "CLUSTERS_FILE",
        "KIBANA_URL",
        "KIBANA_SPACE_ID",
        "KIBANA_API_KEY",
        "KIBANA_USERNAME",
        "KIBANA_PASSWORD",
        "NODE_TLS_REJECT_UNAUTHORIZED"
      ]
    },
    {
      "id": "mcp-app-trino",
      "name": "Trino Visualization",
      "description": "Query Trino or Starburst and render MCP App previews with Elastic Charts.",
