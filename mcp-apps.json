        "type": "git",
        "url": "https://github.com/metalshanked/mcp-app-trino.git",
        "ref": "c46dcf94772ca7b4a1ab41e0b0b8fc52e83999e4"
      },
      "install": [
        ["npm", "install"],
        ["npm", "run", "build"]
      ],
      "transport": {
        "type": "stdio",
        "command": "npm",
        "args": ["run", "start:stdio"],
        "cwd": "${appDir}"
      },
      "envPassthrough": [
        "TRINO_HOST",
        "TRINO_PORT",
        "TRINO_SCHEME",
        "TRINO_SSL",
        "TRINO_USER",
        "TRINO_PASSWORD",
        "TRINO_ACCESS_TOKEN",
        "TRINO_AUTH_TYPE",
        "TRINO_CATALOG",
        "TRINO_SCHEMA",
        "TRINO_SOURCE",
        "TRINO_INSECURE_TLS",
        "TRINO_TLS_INSECURE",
        "TRINO_CA_CERT",
        "TRINO_CA_CERT_FILE",
        "TRINO_TLS_CA_CERT",
        "TRINO_TLS_CA_CERT_FILE",
        "TRINO_CLIENT_CERT",
